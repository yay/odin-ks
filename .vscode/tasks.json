{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Debug Build",
            "type": "shell",
            "command": "cd ${workspaceFolder}/${relativeFileDirname} && odin build . -debug",
            "problemMatcher": {
                "owner": "odin",
                "fileLocation": [
                    "absolute",
                ],
                "pattern": {
                    "regexp": "^(.*)\\((\\d+):(\\d+)\\)\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "message": 4
                }
            }
        }
    ]
}